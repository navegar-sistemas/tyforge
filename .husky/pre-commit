#!/bin/sh

set -e

echo "Running pre-commit checks..."

# 1. TypeScript type check
echo "[1/5] typecheck..."
npm run typecheck

# 2. Tests
echo "[2/5] tests..."
npm run test

# 3. Linter
echo "[3/5] tyforge-lint..."
npx tsx src/lint/index.ts --all

# 4. Docs build (local Docusaurus)
echo "[4/5] docs build (local)..."
cd docs && npm run build
cd ..

# 5. Docs Docker build (production image)
echo "[5/5] docs Docker build..."
if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
  docker build -f docs/Dockerfile docs/ -t tyforge-docs-precommit --quiet
  docker rmi tyforge-docs-precommit --force >/dev/null 2>&1 || true
else
  echo "⚠️  Docker not available — skipping Docker build check"
fi

echo "✅ All pre-commit checks passed."
