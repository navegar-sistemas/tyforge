{
  "name": "tyforge",
  "version": "0.2.8",
  "description": "Type-safe schema validation, Result pattern, and DDD building blocks for TypeScript",
  "keywords": [
    "typescript",
    "validation",
    "schema",
    "ddd",
    "result-pattern",
    "type-fields",
    "domain-driven-design",
    "value-objects",
    "entity",
    "aggregate",
    "type-safe",
    "clean-architecture",
    "exceptions",
    "rfc7807"
  ],
  "author": "Navegar Sistemas",
  "license": "MIT",
  "homepage": "https://navegarsistemas.com.br/opensource/tyforge/",
  "repository": {
    "type": "git",
    "url": "https://github.com/navegar-sistemas/tyforge",
    "directory": "packages/tyforge"
  },
  "bugs": {
    "url": "https://github.com/navegar-sistemas/tyforge/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./result": {
      "react-native": "./dist/result/index.js",
      "import": "./dist/result/index.js",
      "types": "./dist/result/index.d.ts"
    },
    "./type-fields": {
      "react-native": "./dist/type-fields/index.js",
      "import": "./dist/type-fields/index.js",
      "types": "./dist/type-fields/index.d.ts"
    },
    "./exceptions": {
      "react-native": "./dist/exceptions/index.js",
      "import": "./dist/exceptions/index.js",
      "types": "./dist/exceptions/index.d.ts"
    },
    "./schema": {
      "react-native": "./dist/schema/index.js",
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./tools": {
      "react-native": "./dist/tools/index.js",
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./config": {
      "react-native": null,
      "import": "./dist/config/tyforge-config.js",
      "types": "./dist/config/tyforge-config.d.ts"
    },
    "./tools/network-security": {
      "react-native": null,
      "import": "./dist/tools/network-security.tool.js",
      "types": "./dist/tools/network-security.tool.d.ts"
    },
    "./infrastructure/service-base": {
      "react-native": null,
      "import": "./dist/infrastructure/service.base.js",
      "types": "./dist/infrastructure/service.base.d.ts"
    }
  },
  "browser": {
    "./dist/schema/batch-parallel.js": "./dist/schema/batch-parallel.browser.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "precommit": "tsx src/pre-commit/index.ts"
  },
  "dependencies": {
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsdown": "0.21.6",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
