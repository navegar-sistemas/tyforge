{
  "name": "@tyforge/guard",
  "version": "0.1.3",
  "description": "Static analysis for TyForge conventions, architecture rules, and DSL enforcement",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tyforge-guard": "./dist/index.js"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsdown": "0.21.6",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "tyforge": "0.2.8"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
