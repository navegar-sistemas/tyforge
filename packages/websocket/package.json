{
  "name": "@tyforge/websocket",
  "version": "0.1.7",
  "description": "Type-safe WebSocket client with Result pattern, reconnection, security hardening, and exception mapping for TyForge",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "tyforge": "0.2.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsdown": "0.21.6",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "tyforge": "0.2.6"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Navegar Sistemas",
  "repository": {
    "type": "git",
    "url": "https://github.com/navegar-sistemas/tyforge",
    "directory": "packages/websocket"
  },
  "engines": {
    "node": ">=24"
  }
}
