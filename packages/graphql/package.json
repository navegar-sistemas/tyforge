{
  "name": "@tyforge/graphql",
  "version": "0.2.3",
  "description": "Type-safe GraphQL client with Result pattern, introspection blocking, and exception mapping for TyForge",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "dependencies": {
    "graphql": "16.13.2",
    "graphql-request": "7.4.0"
  },
  "peerDependencies": { "tyforge": "0.2.18" },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsdown": "0.21.6",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "tyforge": "0.2.18"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "license": "MIT",
  "author": "Navegar Sistemas",
  "repository": {
    "type": "git",
    "url": "https://github.com/navegar-sistemas/tyforge",
    "directory": "packages/graphql"
  },
  "engines": { "node": ">=24" }
}
