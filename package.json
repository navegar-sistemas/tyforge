{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/tyforge && npm run build && cd ../http && npm run build && cd ../graphql && npm run build && cd ../websocket && npm run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspace=packages/tyforge",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
