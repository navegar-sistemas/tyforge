{
  "name": "tyforge",
  "version": "0.1.0",
  "description": "Type-safe schema validation, Result pattern, and DDD building blocks for TypeScript",
  "keywords": [
    "typescript",
    "validation",
    "schema",
    "ddd",
    "result-pattern",
    "type-fields",
    "domain-driven-design"
  ],
  "author": "Navegar Sistemas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/navegarsistemas/tyforge"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.7.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18"
  }
}
